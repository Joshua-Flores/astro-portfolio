---
import Layout from '~/layouts/Layout.astro'
import Prose from '~/components/posts/base/Prose.astro'
import Badge from '~/components/posts/base/Badge.astro'
import SectionDivider from '~/components/base/SectionDivider.astro'
import TocMobile from '~/components/posts/toc/TocMobile.astro'
import TableOfContents from '~/components/posts/toc/TableOfContents.astro'
import BackToTop from '~/components/posts/toc/BackToTop.astro'
import { formatDate } from '~/lib/utils'
import { POSTS_CONFIG } from '~/config'
import { render } from 'astro:content'
import { getAllProjects } from '~/lib/data'

export async function getStaticPaths() {
  const sortedProjects = await getAllProjects()
  return sortedProjects.map((project, index) => ({
    params: { id: project.id },
    props: {
      project,
      prev: index + 1 < sortedProjects.length ? sortedProjects[index + 1] : null,
      next: index > 0 ? sortedProjects[index - 1] : null,
    },
  }))
}

const { project, prev, next } = Astro.props
const { data } = project
const { Content, headings, remarkPluginFrontmatter } = await render(project)
const filterHeadings = headings.filter((heading: any) => heading.slug !== 'footnote-label')
const hasValidHeadings = filterHeadings.length > 1
---

<Layout title={data.name} description={data.description}>
  <div class="relative flex flex-col justify-between h-fit z-[1]">
    <TocMobile headings={filterHeadings} />
    <article class="relative fade-up">
      <div class="px-6 sm:px-8 py-4 sm:py-6 lg:py-8">
        <div class="global-layout-width mx-auto">
          <header>
            <div class="space-y-4 md:space-y-5">
              {data.description && <p class="text-sm text-muted-foreground/90 leading-relaxed">{data.description}</p>}

              <div class="text-xl lg:text-2xl font-semibold leading-tight" data-pagefind-body>
                {data.name}
              </div>

              <div class="flex flex-wrap items-center gap-3 sm:gap-4 text-sm text-muted-foreground/85">
                <div class="flex items-center gap-1.5">
                  <span class="icon-[ph--calendar-blank] w-4 h-4 opacity-85"></span>
                  <time datetime={data.pubDate.toISOString()}>
                    {formatDate(data.pubDate)}
                  </time>
                </div>

                {remarkPluginFrontmatter.minutesRead && (
                  <div class="flex items-center gap-1.5">
                    <span class="icon-[ph--book-open-text] w-4 h-4 opacity-85" />
                    <span>{remarkPluginFrontmatter.minutesRead} mins</span>
                  </div>
                )}
                {POSTS_CONFIG.wordCountView && remarkPluginFrontmatter.wordCount && (
                  <div class="flex items-center gap-1.5">
                    <span class="icon-[ph--pencil-simple-line] w-4 h-4 opacity-85" />
                    <span>{remarkPluginFrontmatter.wordCount} words</span>
                  </div>
                )}
              </div>

              <div class="flex gap-2 sm:gap-2.5 lg:gap-3 flex-wrap">
                {data.tags?.map((tag: string) => <Badge type="tag" content={tag} size="sm" />)}
              </div>

              <div class="flex items-center gap-5 text-sm">
                {data.website && (
                  <a
                    href={data.website}
                    target="_blank"
                    class="hover:text-primary flex items-center gap-1 text-muted-foreground"
                  >
                    <span class="icon-[mdi--web] size-4" />
                    <span>Website</span>
                  </a>
                )}
                {data.githubUrl && (
                  <a
                    href={data.githubUrl}
                    target="_blank"
                    class="hover:text-primary flex items-center gap-1 text-muted-foreground"
                  >
                    <span class="icon-[mdi--github] size-4" />
                    <span>GitHub</span>
                  </a>
                )}
              </div>
            </div>
            <div class="border-b border-border/60 my-8 sm:my-10 lg:my-12"></div>
          </header>

          <Prose>
            <Content />
          </Prose>
        </div>
      </div>
    </article>

    {(prev || next) && (
      <div class="px-6 sm:px-8 pb-6 sm:pb-8">
        <nav class="flex flex-col sm:flex-row justify-between gap-6 pt-2 border-t border-border/50">
          {next && (
            <a href={`/projects/${next.id}`} class="group flex-1 relative">
              <div class="absolute -left-2 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 group-hover:-translate-x-1 transition-all duration-200">
                <span class="icon-[ph--arrow-left] size-4 text-primary" />
              </div>
              <div class="group-hover:pl-6 transition-all duration-200">
                <span class="text-[10px] uppercase tracking-widest text-muted-foreground/70">Previous</span>
                <p class="mt-1.5 font-semibold text-base text-foreground/90 group-hover:text-primary transition-colors line-clamp-1">
                  {next.data.name}
                </p>
              </div>
            </a>
          )}
          {prev && (
            <a href={`/projects/${prev.id}`} class="group flex-1 relative text-right">
              <div class="absolute -right-2 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-200">
                <span class="icon-[ph--arrow-right] size-4 text-primary" />
              </div>
              <div class="group-hover:pr-6 transition-all duration-200">
                <span class="text-[10px] uppercase tracking-widest text-muted-foreground/70">Next</span>
                <p class="mt-1.5 font-semibold text-base text-foreground/90 group-hover:text-primary transition-colors line-clamp-1">
                  {prev.data.name}
                </p>
              </div>
            </a>
          )}
        </nav>
      </div>
    )}

    {hasValidHeadings && <TableOfContents headings={filterHeadings} class="hidden xl:block fade-up animation-delay-150" />}

    <BackToTop id="backToTopMobile" class="xl:hidden fixed bottom-14 sm:right-8 right-6 z-50 flex flex-col gap-3" />

    <div class="hidden xl:flex fixed bottom-24 right-[calc(50%-384px)] translate-x-full p-4">
      <div class="flex items-center gap-2">
        <BackToTop id="backToTopDesktop" />
      </div>
    </div>

    <SectionDivider />
  </div>
</Layout>
