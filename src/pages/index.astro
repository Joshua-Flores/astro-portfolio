---
import { SITE, SKILLSSHOWCASE_CONFIG, SOCIAL_LINKS } from '~/config.ts'
import { GITHUB_CONFIG, POSTS_CONFIG } from '~/config.ts'
import Layout from '~/layouts/Layout.astro'
import SectionDivider from '~/components/base/SectionDivider.astro'
import GithubContributions from '~/components/base/GithubContributions.tsx'
import SocialLink from '~/components/base/SocialLink.astro'
import List from '~/components/posts/card/List.astro'
import SkillsShowcase from '~/components/base/SkillsShowcase.astro'
import LqipImage from '~/components/base/LqipImage.astro'
import Badge from '~/components/posts/base/Badge.astro'
import { formatDate } from '~/lib/utils'
import { getNumPosts, getPinnedPosts, getNumProjects } from '~/lib/data'

const { ENABLED, GITHUB_USERNAME, TOOLTIP_ENABLED } = GITHUB_CONFIG
const { size, type } = POSTS_CONFIG.homePageConfig
const recentProjects = await getNumProjects(3)
const { SKILLS_ENABLED, SKILLS_DATA } = SKILLSSHOWCASE_CONFIG

let showPosts = []
const pinnedPosts = await getPinnedPosts()
const hasPinnedPosts = pinnedPosts.length > 0
if (hasPinnedPosts) {
  showPosts = pinnedPosts
} else {
  showPosts = await getNumPosts(size)
}
---

<Layout title="Home" description={SITE.description}>
  <div class="relative z-[1]">
    <div class="py-8 pb-10 px-6 sm:px-8">
      <h1 class="flex flex-col gap-2">
        <span class="text-4xl sm:text-5xl tracking-tight">Joshua Flores</span>
        <span class="text-muted-foreground font-light text-xl sm:text-2xl block tracking-wide text-balance">
          UX Designer & Frontend Developer
        </span>
      </h1>
      <div class="pro text-muted-foreground text-pretty">
        <p>
          Senior UX designer and frontend developer with over a decade of experience across industry and government. I design and build
          intuitive, clean interfaces using TypeScript, React, and Tailwind CSS.
        </p>
        <p>
          I write about frontend development, AI-powered workflows, and practical UI design. When I'm not coding, I'm probably researching
          the next tool that'll make the process faster and better.
        </p>
      </div>
      <div class="mt-6 flex gap-6">
        {
          SOCIAL_LINKS.map((item) => {
            return <SocialLink href={item.url} icon={item.icon} aria-label={`Link of ${item.name}`} count={item.count} label="followers" />
          })
        }
      </div>
    </div>

    {
      SKILLS_ENABLED && SKILLS_DATA.length > 0 && (
        <>
          <SectionDivider />
          <div class="py-8 pb-10 px-6 max-md:px-6">
            <div class="px-2 max-md:px-0">
              <h2 class="text-2xl sm:text-3xl tracking-tight">Daily Drivers</h2>
              <p class="text-muted-foreground mb-6 mt-1">What I reach for when building things:</p>
            </div>
            <SkillsShowcase skillsData={SKILLS_DATA} />
          </div>
        </>
      )
    }
    {
      ENABLED && (
        <>
          <SectionDivider />
          <div class="py-8 pb-10 px-6 max-md:px-6">
            <div class="px-2 max-md:px-0">
              <h2 class="text-2xl sm:text-3xl">GitHub Spotlight</h2>
              <p class="text-muted-foreground mb-6 mt-1">GitHub contributions in the past year:</p>
            </div>
            <GithubContributions username={GITHUB_USERNAME} tooltipEnabled={TOOLTIP_ENABLED} client:load transition:animate="none" />
          </div>
        </>
      )
    }
    {
      recentProjects.length > 0 && (
        <>
          <SectionDivider />
          <div class="py-8 pb-10 px-6 sm:px-8">
            <div class="flex items-baseline justify-between mb-6">
              <div>
                <h2 class="text-2xl sm:text-3xl tracking-tight">Recent Projects</h2>
                <p class="text-muted-foreground mt-1">Latest {recentProjects.length} projects I've worked on.</p>
              </div>
              <a href="/projects" class="text-sm text-muted-foreground hover:text-primary transition-colors">
                View all &rarr;
              </a>
            </div>
            <div class="space-y-12">
              {recentProjects.map((project, index) => (
                <article
                  class:list={['group flex flex-col sm:flex-row sm:flex-row-reverse gap-6 sm:gap-10', 'fade-up']}
                  style={`animation-delay: ${index * 100}ms`}
                >
                  <div class="sm:w-2/6 min-[var(--layout-change-width)]:w-2/8 flex flex-col overflow-hidden">
                    <a href={`/projects/${project.id}`} class="block relative">
                      <div class="aspect-[1200/630] overflow-hidden bg-muted/30 relative">
                        {project.data.cover && (
                          <LqipImage
                            src={project.data.cover}
                            alt=""
                            width={1200}
                            height={630}
                            loading="lazy"
                            decoding="async"
                            format="webp"
                            class="w-full h-full object-cover"
                          />
                        )}
                      </div>
                    </a>
                    <a
                      href={`/projects/${project.id}`}
                      class="hidden sm:inline-flex mt-2 items-center gap-2 text-sm font-medium text-foreground/60 hover:text-primary transition-colors group/read"
                    >
                      Read more
                      <span class="icon-[ph--arrow-right] size-4 transition-transform group-hover/read:translate-x-1" />
                    </a>
                  </div>

                  <div class="w-full sm:w-4/6 min-[var(--layout-change-width)]:w-6/8 flex flex-col justify-start">
                    <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground/90 mb-2">
                      <time class="flex items-center gap-2">
                        <span class="icon-[ph--calendar-blank] size-4" />
                        {formatDate(project.data.pubDate)}
                      </time>
                    </div>

                    <a href={`/projects/${project.id}`} class="group/title">
                      <div class="text-base font-semibold transition-colors group-hover/title:text-primary line-clamp-2 leading-5 mb-1">
                        {project.data.name}
                      </div>
                      {project.data.description && (
                        <p class="text-sm text-muted-foreground/80 line-clamp-3 leading-5 mb-3">{project.data.description}</p>
                      )}
                    </a>

                    <div class="flex flex-wrap items-center gap-2 mb-3">
                      {project.data.tags?.map((tag) => (
                        <Badge type="tag" content={tag} />
                      ))}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </>
      )
    }
    <SectionDivider />
    <div class="py-8 pb-10 px-6 sm:px-8">
      <h2 class="text-2xl sm:text-3xl tracking-tight">Posts</h2>
      <p class="text-muted-foreground mb-6 mt-1">
        {hasPinnedPosts ? `Pinned` : 'Recent'}
        {showPosts.length} posts, worth a look.
      </p>
      <List posts={showPosts} {type} coverLayout={POSTS_CONFIG.homePageConfig?.coverLayout} />
    </div>
  </div>
</Layout>
